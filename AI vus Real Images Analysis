    "# %% [code]\n",
    "# Collect all image paths and assign labels (AI = 1, Real = 0)\n",
    "data = []\n",
    "for cat in categories:\n",
    "    # AI images\n",
    "    for img_path in (AI_PATH/cat).glob(\"*.png\"):\n",
    "        data.append([str(img_path), cat, 1])\n",
