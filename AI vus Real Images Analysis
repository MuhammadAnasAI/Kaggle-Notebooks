    "# %% [code]\n",
    "# Create a new learner using ResNet50 (deeper, more accurate)\n",
    "# ✅ Use vision_learner (new name) and ensure accuracy is the callable metric\n",
    "from fastai.metrics import accuracy, error_rate   # re-import to be safe\n",
    "\n",
    "learn50 = vision_learner(dls, resnet50, metrics=[accuracy, error_rate])\n",
    "learn50.fine_tune(5, 1e-3)\n",
    "\n",
    "# Evaluate ResNet50\n",
    "preds50, targets50 = learn50.get_preds()\n",
    "pred_labels50 = preds50.argmax(dim=1).numpy()\n",
    "accuracy50 = (pred_labels50 == targets50.numpy()).mean()\n",
    "print(f\"ResNet50 Validation Accuracy: {accuracy50:.4f}\")"
   ]
