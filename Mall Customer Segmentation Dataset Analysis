    "# Using Elbow Method and Silhouette Score\n",
    "\n",
    "# Prepare features for clustering\n",
    "X = df_scaled[['Annual Income (k$)', 'Spending Score (1-100)']].values\n",
    "# You can also try using all features: X = df_scaled.values\n",
    "\n",
    "# Calculate inertia and silhouette scores for different k values\n",
    "inertia = []\n",
    "silhouette_scores = []\n",
    "K_range = range(2, 11)\n",
    "\n",
    "for k in K_range:\n",
    "    kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)\n",
    "    kmeans.fit(X)\n",
    "    inertia.append(kmeans.inertia_)\n",
    "    silhouette_scores.append(silhouette_score(X, kmeans.labels_))\n",
    "\n",
    "# Plot Elbow Method and Silhouette Scores\n",
    "fig, axes = plt.subplots(1, 2, figsize=(15, 5))\n",
    "\n",
    "# Elbow Method\n",
    "axes[0].plot(K_range, inertia, 'bo-')\n",
    "axes[0].set_xlabel('Number of Clusters (k)')\n",
    "axes[0].set_ylabel('Inertia')\n",
    "axes[0].set_title('Elbow Method for Optimal k')\n",
    "axes[0].grid(True)\n",
    "\n",
    "# Add vertical line at k=5 (elbow point)\n",
