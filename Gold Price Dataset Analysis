    "# Cell 3: Data Preprocessing\n",
    "# Create a copy of the dataframe\n",
    "df_processed = df.copy()\n",
    "\n",
    "print(\"=\"*60)\n",
    "print(\"DATA PREPROCESSING\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# 1. Convert Date column to datetime\n",
    "df_processed['Date'] = pd.to_datetime(df_processed['Date'])\n",
    "print(\"\\n1. Date column converted to datetime\")\n",
    "\n",
    "# 2. Sort by date (important for time series)\n",
    "df_processed = df_processed.sort_values('Date').reset_index(drop=True)\n",
    "print(\"2. Data sorted by date\")\n",
    "\n",
    "# 3. Check for and handle missing values\n",
    "print(\"\\n3. Missing values before handling:\")\n",
    "print(df_processed.isnull().sum())\n",
    "\n",
    "# Forward fill for missing values (common in time series)\n",
    "df_processed = df_processed.fillna(method='ffill')\n",
    "print(\"\\n   Missing values after forward fill:\")\n",
    "print(df_processed.isnull().sum())\n",
    "\n",
    "# 4. Check for duplicates\n",
    "duplicates = df_processed.duplicated().sum()\n",
    "print(f\"\\n4. Number of duplicate rows: {duplicates}\")\n",
    "if duplicates > 0:\n",
    "    df_processed = df_processed.drop_duplicates()\n",
    "    print(f\"   Duplicates removed. New shape: {df_processed.shape}\")\n",
    "\n",
    "# 5. Extract date features\n",
    "df_processed['Year'] = df_processed['Date'].dt.year\n",
    "df_processed['Month'] = df_processed['Date'].dt.month\n",
    "df_processed['Day'] = df_processed['Date'].dt.day\n",
    "df_processed['DayOfWeek'] = df_processed['Date'].dt.dayofweek\n",
    "df_processed['Quarter'] = df_processed['Date'].dt.quarter\n",
    "df_processed['WeekOfYear'] = df_processed['Date'].dt.isocalendar().week.astype(int)\n",
    "\n",
    "print(\"\\n5. Date features extracted:\")\n",
    "print(df_processed[['Date', 'Year', 'Month', 'Day', 'DayOfWeek', 'Quarter', 'WeekOfYear']].head())\n",
    "\n",
    "# 6. Create additional features\n",
    "# Price range (High - Low)\n",
    "df_processed['Price_Range'] = df_processed['High'] - df_processed['Low']\n",
    "\n",
    "# Price change (Close - Open)\n",
    "df_processed['Price_Change'] = df_processed['Close'] - df_processed['Open']\n",
    "\n",
    "# Percentage change\n",
    "df_processed['Pct_Change'] = df_processed['Close'].pct_change() * 100\n",
    "\n",
    "# Moving averages\n",
    "df_processed['MA_7'] = df_processed['Close'].rolling(window=7).mean()\n",
    "df_processed['MA_30'] = df_processed['Close'].rolling(window=30).mean()\n",
    "df_processed['MA_90'] = df_processed['Close'].rolling(window=90).mean()\n",
    "\n",
    "# Volatility (rolling standard deviation)\n",
    "df_processed['Volatility_7'] = df_processed['Close'].rolling(window=7).std()\n",
    "df_processed['Volatility_30'] = df_processed['Close'].rolling(window=30).std()\n",
    "\n",
    "# Price momentum\n",
    "df_processed['Momentum_7'] = df_processed['Close'].diff(7)\n",
    "df_processed['Momentum_30'] = df_processed['Close'].diff(30)\n",
