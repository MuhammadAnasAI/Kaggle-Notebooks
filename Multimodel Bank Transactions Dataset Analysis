    "print(\"=\"*70)\n",
    "print(\"STEP 6: FEATURE ENGINEERING\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "# Create a new dataframe for feature engineering\n",
    "df_fe = df_clean.copy()\n",
    "\n",
    "# 1. Process TransactionDate\n",
    "print(\"\\n📅 Processing TransactionDate...\")\n",
    "if 'TransactionDate' in df_fe.columns:\n",
    "    # Convert to datetime\n",
    "    df_fe['TransactionDate'] = pd.to_datetime(df_fe['TransactionDate'], errors='coerce')\n",
    "    \n",
    "    # Drop rows with invalid dates\n",
    "    invalid_dates = df_fe['TransactionDate'].isna().sum()\n",
    "    if invalid_dates > 0:\n",
    "        print(f\"Dropping {invalid_dates} rows with invalid dates\")\n",
    "        df_fe = df_fe.dropna(subset=['TransactionDate'])\n",
    "    \n",
    "    # Extract date features\n",
    "    df_fe['TransactionHour'] = df_fe['TransactionDate'].dt.hour\n",
    "    df_fe['TransactionDay'] = df_fe['TransactionDate'].dt.day\n",
    "    df_fe['TransactionMonth'] = df_fe['TransactionDate'].dt.month\n",
    "    df_fe['TransactionYear'] = df_fe['TransactionDate'].dt.year\n",
    "    df_fe['TransactionDayOfWeek'] = df_fe['TransactionDate'].dt.dayofweek\n",
    "    df_fe['IsWeekend'] = (df_fe['TransactionDayOfWeek'] >= 5).astype(int)\n",
    "    df_fe['TransactionQuarter'] = df_fe['TransactionDate'].dt.quarter\n",
    "    \n",
    "    print(\"✅ Date features extracted successfully!\")\n",
    "\n",
    "# 2. Create risk indicators\n",
    "print(\"\\n⚠️ Creating risk indicators...\")\n",
    "\n",
    "# High amount risk (top 5%)\n",
    "high_amount_threshold = df_fe['TransactionAmount'].quantile(0.95)\n",
    "df_fe['HighRiskAmount'] = (df_fe['TransactionAmount'] > high_amount_threshold).astype(int)\n",
    "\n",
    "# Multiple login attempts risk\n",
    "median_logins = df_fe['LoginAttempts'].median()\n",
    "df_fe['MultipleLoginAttempts'] = (df_fe['LoginAttempts'] > median_logins).astype(int)\n",
    "\n",
    "# Low balance risk (bottom 10%)\n",
    "low_balance_threshold = df_fe['AccountBalance'].quantile(0.10)\n",
    "df_fe['LowBalanceRisk'] = (df_fe['AccountBalance'] < low_balance_threshold).astype(int)\n",
    "\n",
    "# 3. Create interaction features\n",
    "print(\"\\n🔄 Creating interaction features...\")\n",
    "df_fe['AmountPerLogin'] = df_fe['TransactionAmount'] / (df_fe['LoginAttempts'] + 1)\n",
    "df_fe['BalanceToAmount'] = df_fe['AccountBalance'] / (df_fe['TransactionAmount'] + 1)\n",
    "df_fe['AgeToDuration'] = df_fe['CustomerAge'] / (df_fe['TransactionDuration'] + 1)\n",
    "\n",
    "# 4. Create time-based categories\n",
    "print(\"\\n⏰ Creating time categories...\")\n",
    "def get_time_category(hour):\n",
    "    if pd.isna(hour):\n",
    "        return 'Unknown'\n",
    "    elif 0 <= hour < 6:\n",
    "        return 'Late Night'\n",
    "    elif 6 <= hour < 12:\n",
    "        return 'Morning'\n",
    "    elif 12 <= hour < 18:\n",
    "        return 'Afternoon'\n",
    "    else:\n",
    "        return 'Evening'\n",
    "\n",
    "df_fe['TimeCategory'] = df_fe['TransactionHour'].apply(get_time_category)\n",
