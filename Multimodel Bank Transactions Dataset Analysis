    "missing_before = df_clean.isnull().sum().sum()\n",
    "\n",
    "for col in df_clean.columns:\n",
    "    missing_count = df_clean[col].isnull().sum()\n",
    "    if missing_count > 0:\n",
    "        if df_clean[col].dtype == 'object':\n",
    "            # For categorical columns, fill with mode\n",
    "            mode_value = df_clean[col].mode()[0] if not df_clean[col].mode().empty else 'Unknown'\n",
    "            df_clean[col].fillna(mode_value, inplace=True)\n",
    "            print(f\"  {col}: Filled {missing_count} missing values with mode\")\n",
    "        else:\n",
    "            # For numerical columns, fill with median\n",
    "            median_value = df_clean[col].median()\n",
    "            df_clean[col].fillna(median_value, inplace=True)\n",
    "            print(f\"  {col}: Filled {missing_count} missing values with median\")\n",
    "\n",
    "missing_after = df_clean.isnull().sum().sum()\n",
    "print(f\"\\nTotal missing values handled: {missing_before - missing_after}\")\n",
    "print(f\"Final dataset shape: {df_clean.shape}\")\n",
    "\n",
    "# 3. Handle outliers using IQR method\n",
    "print(\"\\n📌 Handling Outliers...\")\n",
    "numerical_cols = df_clean.select_dtypes(include=[np.number]).columns.tolist()\n",
    "outlier_summary = []\n",
    "\n",
    "for col in numerical_cols:\n",
    "    Q1 = df_clean[col].quantile(0.25)\n",
    "    Q3 = df_clean[col].quantile(0.75)\n",
    "    IQR = Q3 - Q1\n",
    "    lower_bound = Q1 - 1.5 * IQR\n",
    "    upper_bound = Q3 + 1.5 * IQR\n",
    "    \n",
    "    outliers = df_clean[(df_clean[col] < lower_bound) | (df_clean[col] > upper_bound)]\n",
    "    outlier_count = len(outliers)\n",
    "    outlier_percentage = (outlier_count / len(df_clean)) * 100\n",
    "    \n",
    "    outlier_summary.append({\n",
